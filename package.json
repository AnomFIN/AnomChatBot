{
  "name": "anom-chatbot",
  "version": "2.0.0",
  "description": "Human-controlled chatbot bridge: WhatsApp ↔ Telegram ↔ OpenAI with React admin GUI",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:web": "cd web && npm run build"
  },
  "keywords": [
    "whatsapp",
    "telegram",
    "openai",
    "chatbot",
    "bridge",
    "admin-gui",
    "socket.io"
  ],
  "author": "AnomFIN",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/formbody": "^8.0.0",
    "@fastify/static": "^8.0.0",
    "@whiskeysockets/baileys": "^6.7.16",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
