# AnomChatBot Configuration Template
# Copy this file to .env and fill in your actual values

# ── AI Provider ──────────────────────────────────────────────
AI_PROVIDER=openai                # openai | openai-compatible
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini          # Default model
OPENAI_BASE_URL=                   # Override for local endpoints (LM Studio, Ollama)

# ── WhatsApp Transport ───────────────────────────────────────
# WHATSAPP_MODE selects the transport: cloud | baileys
WHATSAPP_MODE=baileys

# Cloud API settings (required when WHATSAPP_MODE=cloud)
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_WEBHOOK_PATH=/webhook/whatsapp

# Baileys settings (used when WHATSAPP_MODE=baileys)
WHATSAPP_AUTH_DIR=./data/baileys-auth

# ── Telegram Admin (optional) ────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_IDS=your_telegram_user_id_here

# ── Web GUI / Fastify ────────────────────────────────────────
HOST=0.0.0.0
PORT=3000

# ── Database ─────────────────────────────────────────────────
DATABASE_PATH=./data/anomchatbot.db

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info                     # error | warn | info | debug

# ── Conversation Defaults ────────────────────────────────────
MAX_CONVERSATION_HISTORY=50
# Canonical tone values:    professional, friendly, casual, playful
# Canonical flirt values:   none, subtle, moderate, high

